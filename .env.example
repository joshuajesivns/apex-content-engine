# --- Apex Content Engine configuration ---

# OpenAI API key (required to actually generate; not needed for --dry-run)
OPENAI_API_KEY=sk-...

# Text model (optional, default: gpt-4o)
APEX_MODEL=gpt-4o

# Image model + size (optional). Set to dall-e-3 if you prefer.
APEX_IMAGE_MODEL=gpt-image-1
APEX_IMAGE_SIZE=1024x1024

# Absolute path to the Apex Engine website repo. Used to build the internal
# link map (existing blog / model / listing pages). Leave blank to disable
# internal linking.
# Example (Windows): APEX_SITE_DIR=C:\Users\Joshua\Desktop\southshift
APEX_SITE_DIR=

# Public base URL of the live site (used for the internal hyperlinks).
APEX_SITE_URL=https://autowebsite-beta.vercel.app

# Where generated Word docs + images are written (default: ./output)
APEX_OUTPUT_DIR=output
